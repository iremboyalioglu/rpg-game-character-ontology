@prefix rpg: <http://example.org/rpg-game-character-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .

rpg: a owl:Ontology ;
    rdfs:label "RPG Game Character Ontology"@en ;
    rdfs:comment "Version 2 of a small-scale ontology for modeling RPG game characters, quests, items, locations, player behavior events, play styles, and simple recommendations."@en ;
    dc:title "RPG Game Character Ontology"@en ;
    dc:creator "İrem Boyalıoğlu" , "Yunus Erdem Ocak" ;
    dc:description "An OWL/RDF ontology for a small-scale RPG game character and quest knowledge graph, extended in v2 with data acquisition, player behavior events, and recommendation-oriented concepts."@en ;
    owl:versionInfo "2.0" ;
    vann:preferredNamespacePrefix "rpg" ;
    vann:preferredNamespaceUri "http://example.org/rpg-game-character-ontology#" .

#################################################################
# Classes - TBox
#################################################################

rpg:GameEntity a owl:Class ;
    rdfs:label "Game Entity"@en ;
    rdfs:comment "A general entity that exists in the RPG game world."@en .

rpg:GameCharacter a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Game Character"@en ;
    rdfs:comment "A character entity in the game world."@en .

rpg:PlayerCharacter a owl:Class ;
    rdfs:subClassOf rpg:GameCharacter ;
    rdfs:label "Player Character"@en ;
    rdfs:comment "A character controlled by the player."@en .

rpg:NonPlayerCharacter a owl:Class ;
    rdfs:subClassOf rpg:GameCharacter ;
    rdfs:label "Non-Player Character"@en ;
    rdfs:comment "A character controlled by the game system."@en .

rpg:Enemy a owl:Class ;
    rdfs:subClassOf rpg:GameCharacter ;
    rdfs:label "Enemy"@en ;
    rdfs:comment "A hostile character that can oppose player characters."@en .

rpg:BossEnemy a owl:Class ;
    rdfs:subClassOf rpg:Enemy ;
    rdfs:label "Boss Enemy"@en ;
    rdfs:comment "A powerful enemy usually associated with an important challenge."@en .

rpg:CharacterClass a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Character Class"@en ;
    rdfs:comment "A role or profession of a character, such as Warrior, Mage, Ranger, or Sage."@en .

rpg:Race a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Race"@en ;
    rdfs:comment "The species or ancestry of a character."@en .

rpg:Skill a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Skill"@en ;
    rdfs:comment "An ability that can be used by a character."@en .

rpg:Equipment a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Equipment"@en ;
    rdfs:comment "An item that can be equipped by a character."@en .

rpg:Weapon a owl:Class ;
    rdfs:subClassOf rpg:Equipment ;
    rdfs:label "Weapon"@en ;
    rdfs:comment "Equipment used by a character for attacking."@en .

rpg:Armor a owl:Class ;
    rdfs:subClassOf rpg:Equipment ;
    rdfs:label "Armor"@en ;
    rdfs:comment "Equipment used by a character for protection."@en .

rpg:Item a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Item"@en ;
    rdfs:comment "A general object in the game world."@en .

rpg:ConsumableItem a owl:Class ;
    rdfs:subClassOf rpg:Item ;
    rdfs:label "Consumable Item"@en ;
    rdfs:comment "An item that can be consumed by a character."@en .

rpg:Quest a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Quest"@en ;
    rdfs:comment "A mission or task in the game world."@en .

rpg:Location a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Location"@en ;
    rdfs:comment "A place or area in the game world."@en .

rpg:Faction a owl:Class ;
    rdfs:subClassOf rpg:GameEntity ;
    rdfs:label "Faction"@en ;
    rdfs:comment "A group or organization that characters may belong to."@en .

rpg:Player a owl:Class ;
    rdfs:label "Player"@en ;
    rdfs:comment "A human user or player profile that controls one or more player characters."@en .

rpg:GameplayEvent a owl:Class ;
    rdfs:label "Gameplay Event"@en ;
    rdfs:comment "An event generated by player activity, such as completing a quest or using a skill."@en .

rpg:QuestCompletion a owl:Class ;
    rdfs:subClassOf rpg:GameplayEvent ;
    rdfs:label "Quest Completion"@en ;
    rdfs:comment "A gameplay event representing the completion of a quest."@en .

rpg:SkillUsage a owl:Class ;
    rdfs:subClassOf rpg:GameplayEvent ;
    rdfs:label "Skill Usage"@en ;
    rdfs:comment "A gameplay event representing the use of a skill by a character."@en .

rpg:CharacterProgression a owl:Class ;
    rdfs:label "Character Progression"@en ;
    rdfs:comment "A representation of character development over time, such as level growth or repeated skill usage."@en .

rpg:PlayStyle a owl:Class ;
    rdfs:label "Play Style"@en ;
    rdfs:comment "A high-level behavioral category inferred from player activity, such as Explorer, CombatFocused, or QuestOriented."@en .

rpg:Recommendation a owl:Class ;
    rdfs:label "Recommendation"@en ;
    rdfs:comment "A suggested quest, skill, or item generated from ontology-based player and character information."@en .

#################################################################
# Object Properties - TBox
#################################################################

rpg:hasClass a owl:ObjectProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:CharacterClass ; rdfs:label "has class"@en ; rdfs:comment "Relates a game character to a character class."@en .
rpg:hasRace a owl:ObjectProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:Race ; rdfs:label "has race"@en ; rdfs:comment "Relates a game character to a race."@en .
rpg:hasSkill a owl:ObjectProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:Skill ; rdfs:label "has skill"@en ; rdfs:comment "Relates a game character to a skill."@en .
rpg:usesWeapon a owl:ObjectProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:Weapon ; rdfs:label "uses weapon"@en ; rdfs:comment "Relates a game character to a weapon used by that character."@en .
rpg:wearsArmor a owl:ObjectProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:Armor ; rdfs:label "wears armor"@en ; rdfs:comment "Relates a game character to armor worn by that character."@en .
rpg:belongsToFaction a owl:ObjectProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:Faction ; rdfs:label "belongs to faction"@en ; rdfs:comment "Relates a game character to a faction."@en .
rpg:locatedIn a owl:ObjectProperty ; rdfs:domain rpg:GameEntity ; rdfs:range rpg:Location ; rdfs:label "located in"@en ; rdfs:comment "Relates a game entity to a location."@en .
rpg:givesQuest a owl:ObjectProperty ; rdfs:domain rpg:NonPlayerCharacter ; rdfs:range rpg:Quest ; rdfs:label "gives quest"@en ; rdfs:comment "Relates an NPC to a quest that the NPC gives."@en .
rpg:participatesInQuest a owl:ObjectProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:Quest ; rdfs:label "participates in quest"@en ; rdfs:comment "Relates a character to a quest in which the character participates."@en .
rpg:allyOf a owl:ObjectProperty, owl:SymmetricProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:GameCharacter ; rdfs:label "ally of"@en ; rdfs:comment "Relates two game characters that are allies."@en .
rpg:enemyOf a owl:ObjectProperty, owl:SymmetricProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range rpg:GameCharacter ; rdfs:label "enemy of"@en ; rdfs:comment "Relates two game characters that are enemies."@en .
rpg:requiresSkill a owl:ObjectProperty ; rdfs:domain rpg:Quest ; rdfs:range rpg:Skill ; rdfs:label "requires skill"@en ; rdfs:comment "Relates a quest to a skill required for completing it."@en .
rpg:rewardsItem a owl:ObjectProperty ; rdfs:domain rpg:Quest ; rdfs:range rpg:Item ; rdfs:label "rewards item"@en ; rdfs:comment "Relates a quest to an item rewarded after completion."@en .

rpg:controlsCharacter a owl:ObjectProperty ; rdfs:domain rpg:Player ; rdfs:range rpg:PlayerCharacter ; rdfs:label "controls character"@en ; rdfs:comment "Relates a player profile to the player character controlled by that player."@en .
rpg:performsEvent a owl:ObjectProperty ; rdfs:domain rpg:Player ; rdfs:range rpg:GameplayEvent ; rdfs:label "performs event"@en ; rdfs:comment "Relates a player to a gameplay event performed by that player."@en .
rpg:eventForCharacter a owl:ObjectProperty ; rdfs:domain rpg:GameplayEvent ; rdfs:range rpg:GameCharacter ; rdfs:label "event for character"@en ; rdfs:comment "Relates a gameplay event to the character involved in that event."@en .
rpg:eventRelatedQuest a owl:ObjectProperty ; rdfs:domain rpg:GameplayEvent ; rdfs:range rpg:Quest ; rdfs:label "event related quest"@en ; rdfs:comment "Relates a gameplay event to the quest involved in the event."@en .
rpg:eventUsesSkill a owl:ObjectProperty ; rdfs:domain rpg:SkillUsage ; rdfs:range rpg:Skill ; rdfs:label "event uses skill"@en ; rdfs:comment "Relates a skill usage event to the skill used."@en .
rpg:completedQuest a owl:ObjectProperty ; rdfs:domain rpg:QuestCompletion ; rdfs:range rpg:Quest ; rdfs:label "completed quest"@en ; rdfs:comment "Relates a quest completion event to the completed quest."@en .
rpg:hasPlayStyle a owl:ObjectProperty ; rdfs:domain rpg:Player ; rdfs:range rpg:PlayStyle ; rdfs:label "has play style"@en ; rdfs:comment "Relates a player to a high-level play style category."@en .
rpg:recommendationForPlayer a owl:ObjectProperty ; rdfs:domain rpg:Recommendation ; rdfs:range rpg:Player ; rdfs:label "recommendation for player"@en ; rdfs:comment "Relates a recommendation to the player for whom it was generated."@en .
rpg:recommendedQuest a owl:ObjectProperty ; rdfs:domain rpg:Recommendation ; rdfs:range rpg:Quest ; rdfs:label "recommended quest"@en ; rdfs:comment "Relates a recommendation to a suggested quest."@en .
rpg:recommendedSkill a owl:ObjectProperty ; rdfs:domain rpg:Recommendation ; rdfs:range rpg:Skill ; rdfs:label "recommended skill"@en ; rdfs:comment "Relates a recommendation to a suggested skill."@en .

#################################################################
# Data Properties - TBox
#################################################################

rpg:characterName a owl:DatatypeProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range xsd:string ; rdfs:label "character name"@en ; rdfs:comment "Textual display name of a character."@en .
rpg:level a owl:DatatypeProperty ; rdfs:domain rpg:GameCharacter ; rdfs:range xsd:integer ; rdfs:label "level"@en ; rdfs:comment "Numeric level of a game character."@en .
rpg:questTitle a owl:DatatypeProperty ; rdfs:domain rpg:Quest ; rdfs:range xsd:string ; rdfs:label "quest title"@en ; rdfs:comment "Textual title of a quest."@en .
rpg:locationName a owl:DatatypeProperty ; rdfs:domain rpg:Location ; rdfs:range xsd:string ; rdfs:label "location name"@en ; rdfs:comment "Textual display name of a location."@en .
rpg:itemName a owl:DatatypeProperty ; rdfs:domain rpg:Item ; rdfs:range xsd:string ; rdfs:label "item name"@en ; rdfs:comment "Textual display name of an item."@en .
rpg:playerName a owl:DatatypeProperty ; rdfs:domain rpg:Player ; rdfs:range xsd:string ; rdfs:label "player name"@en ; rdfs:comment "Textual display name of a player profile."@en .
rpg:eventTimestamp a owl:DatatypeProperty ; rdfs:domain rpg:GameplayEvent ; rdfs:range xsd:dateTime ; rdfs:label "event timestamp"@en ; rdfs:comment "Timestamp of a gameplay event."@en .
rpg:eventCount a owl:DatatypeProperty ; rdfs:domain rpg:GameplayEvent ; rdfs:range xsd:integer ; rdfs:label "event count"@en ; rdfs:comment "Number of times a repeated gameplay behavior occurred in the sample data."@en .
rpg:completionStatus a owl:DatatypeProperty ; rdfs:domain rpg:QuestCompletion ; rdfs:range xsd:string ; rdfs:label "completion status"@en ; rdfs:comment "Completion state of a quest event."@en .
rpg:preferenceScore a owl:DatatypeProperty ; rdfs:domain rpg:Recommendation ; rdfs:range xsd:decimal ; rdfs:label "preference score"@en ; rdfs:comment "Simple score used to rank a recommendation in the sample knowledge graph."@en .
rpg:recommendationReason a owl:DatatypeProperty ; rdfs:domain rpg:Recommendation ; rdfs:range xsd:string ; rdfs:label "recommendation reason"@en ; rdfs:comment "Textual explanation for why a recommendation was generated."@en .

#################################################################
# Individuals - ABox
#################################################################

# Character classes
rpg:Warrior a rpg:CharacterClass ; rdfs:label "Warrior"@en .
rpg:Mage a rpg:CharacterClass ; rdfs:label "Mage"@en .
rpg:Ranger a rpg:CharacterClass ; rdfs:label "Ranger"@en .
rpg:Sage a rpg:CharacterClass ; rdfs:label "Sage"@en .

# Races
rpg:Human a rpg:Race ; rdfs:label "Human"@en .
rpg:Elf a rpg:Race ; rdfs:label "Elf"@en .
rpg:Orc a rpg:Race ; rdfs:label "Orc"@en .

# Skills
rpg:PowerStrike a rpg:Skill ; rdfs:label "Power Strike"@en .
rpg:Fireball a rpg:Skill ; rdfs:label "Fireball"@en .
rpg:StealthShot a rpg:Skill ; rdfs:label "Stealth Shot"@en .
rpg:ShieldBlock a rpg:Skill ; rdfs:label "Shield Block"@en .
rpg:ArcaneShield a rpg:Skill ; rdfs:label "Arcane Shield"@en .
rpg:Tracking a rpg:Skill ; rdfs:label "Tracking"@en .
rpg:AncientKnowledge a rpg:Skill ; rdfs:label "Ancient Knowledge"@en .
rpg:ShadowCurse a rpg:Skill ; rdfs:label "Shadow Curse"@en .

# Items and equipment
rpg:IronSword a rpg:Weapon ; rdfs:label "Iron Sword"@en .
rpg:OakStaff a rpg:Weapon ; rdfs:label "Oak Staff"@en .
rpg:HunterBow a rpg:Weapon ; rdfs:label "Hunter Bow"@en .
rpg:ShadowStaff a rpg:Weapon ; rdfs:label "Shadow Staff"@en .
rpg:LeatherArmor a rpg:Armor ; rdfs:label "Leather Armor"@en .
rpg:ClothRobe a rpg:Armor ; rdfs:label "Cloth Robe"@en .
rpg:DarkArmor a rpg:Armor ; rdfs:label "Dark Armor"@en .
rpg:HealingPotion a rpg:ConsumableItem ; rpg:itemName "Healing Potion" .
rpg:ManaPotion a rpg:ConsumableItem ; rpg:itemName "Mana Potion" .
rpg:AncientAmulet a rpg:Item ; rpg:itemName "Ancient Amulet" .

# Locations
rpg:OldVillage a rpg:Location ; rpg:locationName "Old Village" .
rpg:DarkForest a rpg:Location ; rpg:locationName "Dark Forest" .
rpg:ShadowCastle a rpg:Location ; rpg:locationName "Shadow Castle" .

# Factions
rpg:AdventurersGuild a rpg:Faction ; rdfs:label "Adventurers Guild"@en .
rpg:ShadowCult a rpg:Faction ; rdfs:label "Shadow Cult"@en .

# Quests
rpg:LostRelicQuest a rpg:Quest ; rpg:questTitle "The Lost Relic" ; rpg:requiresSkill rpg:PowerStrike ; rpg:rewardsItem rpg:HealingPotion ; rpg:locatedIn rpg:DarkForest .
rpg:ShadowGateQuest a rpg:Quest ; rpg:questTitle "The Shadow Gate" ; rpg:requiresSkill rpg:Fireball ; rpg:rewardsItem rpg:AncientAmulet ; rpg:locatedIn rpg:ShadowCastle .
rpg:HerbGatheringQuest a rpg:Quest ; rpg:questTitle "Forest Herbs" ; rpg:requiresSkill rpg:Tracking ; rpg:rewardsItem rpg:ManaPotion ; rpg:locatedIn rpg:DarkForest .

# Characters
rpg:Arin a rpg:PlayerCharacter ; rpg:characterName "Arin" ; rpg:level 12 ; rpg:hasClass rpg:Warrior ; rpg:hasRace rpg:Human ; rpg:hasSkill rpg:PowerStrike, rpg:ShieldBlock ; rpg:usesWeapon rpg:IronSword ; rpg:wearsArmor rpg:LeatherArmor ; rpg:belongsToFaction rpg:AdventurersGuild ; rpg:locatedIn rpg:OldVillage ; rpg:participatesInQuest rpg:LostRelicQuest ; rpg:allyOf rpg:Lyra ; rpg:enemyOf rpg:DarkLord .
rpg:Lyra a rpg:PlayerCharacter ; rpg:characterName "Lyra" ; rpg:level 10 ; rpg:hasClass rpg:Mage ; rpg:hasRace rpg:Elf ; rpg:hasSkill rpg:Fireball, rpg:ArcaneShield ; rpg:usesWeapon rpg:OakStaff ; rpg:wearsArmor rpg:ClothRobe ; rpg:belongsToFaction rpg:AdventurersGuild ; rpg:locatedIn rpg:OldVillage ; rpg:participatesInQuest rpg:LostRelicQuest, rpg:ShadowGateQuest ; rpg:enemyOf rpg:DarkLord .
rpg:Kael a rpg:PlayerCharacter ; rpg:characterName "Kael" ; rpg:level 8 ; rpg:hasClass rpg:Ranger ; rpg:hasRace rpg:Human ; rpg:hasSkill rpg:StealthShot, rpg:Tracking ; rpg:usesWeapon rpg:HunterBow ; rpg:wearsArmor rpg:LeatherArmor ; rpg:belongsToFaction rpg:AdventurersGuild ; rpg:locatedIn rpg:DarkForest ; rpg:participatesInQuest rpg:HerbGatheringQuest ; rpg:allyOf rpg:Arin .
rpg:ElderMira a rpg:NonPlayerCharacter ; rpg:characterName "Elder Mira" ; rpg:level 20 ; rpg:hasClass rpg:Sage ; rpg:hasRace rpg:Human ; rpg:hasSkill rpg:AncientKnowledge ; rpg:belongsToFaction rpg:AdventurersGuild ; rpg:locatedIn rpg:OldVillage ; rpg:givesQuest rpg:LostRelicQuest, rpg:ShadowGateQuest, rpg:HerbGatheringQuest .
rpg:GoblinWarrior a rpg:Enemy ; rpg:characterName "Goblin Warrior" ; rpg:level 5 ; rpg:hasClass rpg:Warrior ; rpg:hasRace rpg:Orc ; rpg:hasSkill rpg:PowerStrike ; rpg:usesWeapon rpg:IronSword ; rpg:wearsArmor rpg:LeatherArmor ; rpg:belongsToFaction rpg:ShadowCult ; rpg:locatedIn rpg:DarkForest ; rpg:enemyOf rpg:Arin .
rpg:DarkLord a rpg:BossEnemy ; rpg:characterName "Dark Lord" ; rpg:level 40 ; rpg:hasClass rpg:Mage ; rpg:hasRace rpg:Human ; rpg:hasSkill rpg:Fireball, rpg:ShadowCurse ; rpg:usesWeapon rpg:ShadowStaff ; rpg:wearsArmor rpg:DarkArmor ; rpg:belongsToFaction rpg:ShadowCult ; rpg:locatedIn rpg:ShadowCastle ; rpg:enemyOf rpg:Arin, rpg:Lyra, rpg:Kael .

# Players and behavior data
rpg:Player001 a rpg:Player ; rpg:playerName "Sample Player 001" ; rpg:controlsCharacter rpg:Arin ; rpg:hasPlayStyle rpg:CombatFocused ; rpg:performsEvent rpg:Event001, rpg:Event002 .
rpg:Player002 a rpg:Player ; rpg:playerName "Sample Player 002" ; rpg:controlsCharacter rpg:Lyra ; rpg:hasPlayStyle rpg:MagicFocused ; rpg:performsEvent rpg:Event003 .
rpg:Player003 a rpg:Player ; rpg:playerName "Sample Player 003" ; rpg:controlsCharacter rpg:Kael ; rpg:hasPlayStyle rpg:Explorer ; rpg:performsEvent rpg:Event004 .

rpg:CombatFocused a rpg:PlayStyle ; rdfs:label "Combat Focused"@en .
rpg:MagicFocused a rpg:PlayStyle ; rdfs:label "Magic Focused"@en .
rpg:Explorer a rpg:PlayStyle ; rdfs:label "Explorer"@en .

rpg:Event001 a rpg:QuestCompletion ; rpg:eventForCharacter rpg:Arin ; rpg:eventRelatedQuest rpg:LostRelicQuest ; rpg:completedQuest rpg:LostRelicQuest ; rpg:completionStatus "completed" ; rpg:eventCount 1 ; rpg:eventTimestamp "2026-04-20T18:30:00"^^xsd:dateTime .
rpg:Event002 a rpg:SkillUsage ; rpg:eventForCharacter rpg:Arin ; rpg:eventRelatedQuest rpg:LostRelicQuest ; rpg:eventUsesSkill rpg:PowerStrike ; rpg:eventCount 7 ; rpg:eventTimestamp "2026-04-20T18:45:00"^^xsd:dateTime .
rpg:Event003 a rpg:SkillUsage ; rpg:eventForCharacter rpg:Lyra ; rpg:eventRelatedQuest rpg:ShadowGateQuest ; rpg:eventUsesSkill rpg:Fireball ; rpg:eventCount 12 ; rpg:eventTimestamp "2026-04-21T20:00:00"^^xsd:dateTime .
rpg:Event004 a rpg:QuestCompletion ; rpg:eventForCharacter rpg:Kael ; rpg:eventRelatedQuest rpg:HerbGatheringQuest ; rpg:completedQuest rpg:HerbGatheringQuest ; rpg:completionStatus "completed" ; rpg:eventCount 1 ; rpg:eventTimestamp "2026-04-22T17:20:00"^^xsd:dateTime .

# Example recommendations
rpg:Recommendation001 a rpg:Recommendation ; rpg:recommendationForPlayer rpg:Player001 ; rpg:recommendedQuest rpg:ShadowGateQuest ; rpg:recommendedSkill rpg:ShieldBlock ; rpg:preferenceScore 0.82 ; rpg:recommendationReason "Player001 frequently uses Warrior-related skills and has completed the prerequisite LostRelicQuest." .
rpg:Recommendation002 a rpg:Recommendation ; rpg:recommendationForPlayer rpg:Player002 ; rpg:recommendedQuest rpg:ShadowGateQuest ; rpg:recommendedSkill rpg:ArcaneShield ; rpg:preferenceScore 0.90 ; rpg:recommendationReason "Player002 controls a Mage character and frequently uses Fireball." .
