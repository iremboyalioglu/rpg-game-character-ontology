PREFIX rpg: <http://example.org/rpg-game-character-ontology#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# CQ1 - Which class does each character belong to?
SELECT ?character ?class WHERE {
  ?character a/rdfs:subClassOf* rpg:GameCharacter ;
             rpg:hasClass ?class .
}

# CQ2 - Which skills does a character have?
SELECT ?character ?skill WHERE {
  ?character a/rdfs:subClassOf* rpg:GameCharacter ;
             rpg:hasSkill ?skill .
}

# CQ3 - Which NPC gives each quest?
SELECT ?npc ?quest WHERE {
  ?npc a rpg:NonPlayerCharacter ;
       rpg:givesQuest ?quest .
}

# CQ4 - Which enemies are located in DarkForest?
SELECT ?enemy WHERE {
  ?enemy a/rdfs:subClassOf* rpg:Enemy ;
         rpg:locatedIn rpg:DarkForest .
}

# CQ5 - List all enemies, including BossEnemy individuals through subclass hierarchy.
SELECT ?enemy ?type WHERE {
  ?enemy a ?type .
  ?type rdfs:subClassOf* rpg:Enemy .
}

# CQ6 - Count how many skills each character has.
SELECT ?character (COUNT(?skill) AS ?skillCount) WHERE {
  ?character a/rdfs:subClassOf* rpg:GameCharacter ;
             rpg:hasSkill ?skill .
}
GROUP BY ?character
ORDER BY DESC(?skillCount)

# CQ7 - Which quests has each player completed?
SELECT ?player ?character ?quest WHERE {
  ?player a rpg:Player ;
          rpg:controlsCharacter ?character ;
          rpg:performsEvent ?event .
  ?event a rpg:QuestCompletion ;
         rpg:completedQuest ?quest .
}

# CQ8 - What play style is assigned to each player?
SELECT ?player ?playStyle WHERE {
  ?player a rpg:Player ;
          rpg:hasPlayStyle ?playStyle .
}

# CQ9 - Which recommendations are generated for each player?
SELECT ?player ?recommendation ?quest ?skill ?score WHERE {
  ?recommendation a rpg:Recommendation ;
                  rpg:recommendationForPlayer ?player ;
                  rpg:preferenceScore ?score .
  OPTIONAL { ?recommendation rpg:recommendedQuest ?quest . }
  OPTIONAL { ?recommendation rpg:recommendedSkill ?skill . }
}
ORDER BY DESC(?score)

# CQ10 - Which skills are frequently used in gameplay events?
SELECT ?skill (SUM(?count) AS ?totalUsage) WHERE {
  ?event a rpg:SkillUsage ;
         rpg:eventUsesSkill ?skill ;
         rpg:eventCount ?count .
}
GROUP BY ?skill
ORDER BY DESC(?totalUsage)
