@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rpg: <http://example.org/rpg-game-character-ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

rpg:GameCharacterShape
    a sh:NodeShape ;
    sh:targetClass rpg:GameCharacter ;
    sh:property [
        sh:path rpg:characterName ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every game character must have a character name." ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path rpg:level ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message "Every game character must have a numeric level greater than or equal to 1." ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path rpg:hasClass ;
        sh:minCount 1 ;
        sh:class rpg:CharacterClass ;
        sh:message "Every game character should be connected to at least one character class." ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path rpg:locatedIn ;
        sh:minCount 1 ;
        sh:class rpg:Location ;
        sh:message "Every game character should have at least one known location." ;
        sh:severity sh:Warning
    ] .

rpg:QuestShape
    a sh:NodeShape ;
    sh:targetClass rpg:Quest ;
    sh:property [
        sh:path rpg:questTitle ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every quest must have a quest title." ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path rpg:requiresSkill ;
        sh:minCount 1 ;
        sh:class rpg:Skill ;
        sh:message "Every quest should specify at least one required skill." ;
        sh:severity sh:Warning
    ] .

rpg:PlayerShape
    a sh:NodeShape ;
    sh:targetClass rpg:Player ;
    sh:property [
        sh:path rpg:playerName ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every player profile must have a player name." ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path rpg:controlsCharacter ;
        sh:minCount 1 ;
        sh:class rpg:PlayerCharacter ;
        sh:message "Every player profile should control at least one player character." ;
        sh:severity sh:Violation
    ] .

rpg:GameplayEventShape
    a sh:NodeShape ;
    sh:targetClass rpg:GameplayEvent ;
    sh:property [
        sh:path rpg:eventForCharacter ;
        sh:minCount 1 ;
        sh:class rpg:GameCharacter ;
        sh:message "Every gameplay event must be connected to a game character." ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path rpg:eventTimestamp ;
        sh:minCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "Every gameplay event must have an event timestamp." ;
        sh:severity sh:Violation
    ] .

rpg:RecommendationShape
    a sh:NodeShape ;
    sh:targetClass rpg:Recommendation ;
    sh:property [
        sh:path rpg:recommendationForPlayer ;
        sh:minCount 1 ;
        sh:class rpg:Player ;
        sh:message "Every recommendation must be connected to a player." ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path rpg:preferenceScore ;
        sh:minCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Every recommendation must have a preference score between 0.0 and 1.0." ;
        sh:severity sh:Warning
    ] .
