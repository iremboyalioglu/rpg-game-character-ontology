<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/rpg-game-character-ontology#"
     xml:base="http://example.org/rpg-game-character-ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:rpg-game-character-ontology="http://example.org/rpg-game-character-ontology#">
    <owl:Ontology rdf:about="http://example.org/rpg-game-character-ontology#">
        <terms:creator>Yunus Erdem Ocak</terms:creator>
        <terms:creator>İrem Boyalıoğlu</terms:creator>
        <terms:description xml:lang="en">An OWL/RDF ontology for a small-scale RPG game character and quest knowledge graph, extended in v2 with data acquisition, player behavior events, and recommendation-oriented concepts.</terms:description>
        <terms:title xml:lang="en">RPG Game Character Ontology</terms:title>
        <vann:preferredNamespacePrefix>rpg</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://example.org/rpg-game-character-ontology#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Version 2 of a small-scale ontology for modeling RPG game characters, quests, items, locations, player behavior events, play styles, and simple recommendations.</rdfs:comment>
        <rdfs:label xml:lang="en">RPG Game Character Ontology</rdfs:label>
        <owl:versionInfo>2.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/rpg-game-character-ontology#allyOf -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#allyOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:comment xml:lang="en">Relates two game characters that are allies.</rdfs:comment>
        <rdfs:label xml:lang="en">ally of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#belongsToFaction -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#belongsToFaction">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Faction"/>
        <rdfs:comment xml:lang="en">Relates a game character to a faction.</rdfs:comment>
        <rdfs:label xml:lang="en">belongs to faction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#completedQuest -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#completedQuest">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#QuestCompletion"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:comment xml:lang="en">Relates a quest completion event to the completed quest.</rdfs:comment>
        <rdfs:label xml:lang="en">completed quest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#controlsCharacter -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#controlsCharacter">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Player"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#PlayerCharacter"/>
        <rdfs:comment xml:lang="en">Relates a player profile to the player character controlled by that player.</rdfs:comment>
        <rdfs:label xml:lang="en">controls character</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#enemyOf -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#enemyOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:comment xml:lang="en">Relates two game characters that are enemies.</rdfs:comment>
        <rdfs:label xml:lang="en">enemy of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#eventForCharacter -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#eventForCharacter">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameplayEvent"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:comment xml:lang="en">Relates a gameplay event to the character involved in that event.</rdfs:comment>
        <rdfs:label xml:lang="en">event for character</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#eventRelatedQuest -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#eventRelatedQuest">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameplayEvent"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:comment xml:lang="en">Relates a gameplay event to the quest involved in the event.</rdfs:comment>
        <rdfs:label xml:lang="en">event related quest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#eventUsesSkill -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#eventUsesSkill">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#SkillUsage"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Skill"/>
        <rdfs:comment xml:lang="en">Relates a skill usage event to the skill used.</rdfs:comment>
        <rdfs:label xml:lang="en">event uses skill</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#givesQuest -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#givesQuest">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#NonPlayerCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:comment xml:lang="en">Relates an NPC to a quest that the NPC gives.</rdfs:comment>
        <rdfs:label xml:lang="en">gives quest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#hasClass -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#hasClass">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#CharacterClass"/>
        <rdfs:comment xml:lang="en">Relates a game character to a character class.</rdfs:comment>
        <rdfs:label xml:lang="en">has class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#hasPlayStyle -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#hasPlayStyle">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Player"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#PlayStyle"/>
        <rdfs:comment xml:lang="en">Relates a player to a high-level play style category.</rdfs:comment>
        <rdfs:label xml:lang="en">has play style</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#hasRace -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#hasRace">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Race"/>
        <rdfs:comment xml:lang="en">Relates a game character to a race.</rdfs:comment>
        <rdfs:label xml:lang="en">has race</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#hasSkill -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#hasSkill">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Skill"/>
        <rdfs:comment xml:lang="en">Relates a game character to a skill.</rdfs:comment>
        <rdfs:label xml:lang="en">has skill</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#locatedIn -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#locatedIn">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameEntity"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Location"/>
        <rdfs:comment xml:lang="en">Relates a game entity to a location.</rdfs:comment>
        <rdfs:label xml:lang="en">located in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#participatesInQuest -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#participatesInQuest">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:comment xml:lang="en">Relates a character to a quest in which the character participates.</rdfs:comment>
        <rdfs:label xml:lang="en">participates in quest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#performsEvent -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#performsEvent">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Player"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#GameplayEvent"/>
        <rdfs:comment xml:lang="en">Relates a player to a gameplay event performed by that player.</rdfs:comment>
        <rdfs:label xml:lang="en">performs event</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#recommendationForPlayer -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#recommendationForPlayer">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Recommendation"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Player"/>
        <rdfs:comment xml:lang="en">Relates a recommendation to the player for whom it was generated.</rdfs:comment>
        <rdfs:label xml:lang="en">recommendation for player</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#recommendedQuest -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#recommendedQuest">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Recommendation"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:comment xml:lang="en">Relates a recommendation to a suggested quest.</rdfs:comment>
        <rdfs:label xml:lang="en">recommended quest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#recommendedSkill -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#recommendedSkill">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Recommendation"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Skill"/>
        <rdfs:comment xml:lang="en">Relates a recommendation to a suggested skill.</rdfs:comment>
        <rdfs:label xml:lang="en">recommended skill</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#requiresSkill -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#requiresSkill">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Skill"/>
        <rdfs:comment xml:lang="en">Relates a quest to a skill required for completing it.</rdfs:comment>
        <rdfs:label xml:lang="en">requires skill</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#rewardsItem -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#rewardsItem">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Item"/>
        <rdfs:comment xml:lang="en">Relates a quest to an item rewarded after completion.</rdfs:comment>
        <rdfs:label xml:lang="en">rewards item</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#usesWeapon -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#usesWeapon">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Weapon"/>
        <rdfs:comment xml:lang="en">Relates a game character to a weapon used by that character.</rdfs:comment>
        <rdfs:label xml:lang="en">uses weapon</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#wearsArmor -->


    <owl:ObjectProperty rdf:about="http://example.org/rpg-game-character-ontology#wearsArmor">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://example.org/rpg-game-character-ontology#Armor"/>
        <rdfs:comment xml:lang="en">Relates a game character to armor worn by that character.</rdfs:comment>
        <rdfs:label xml:lang="en">wears armor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/rpg-game-character-ontology#characterName -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#characterName">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual display name of a character.</rdfs:comment>
        <rdfs:label xml:lang="en">character name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#completionStatus -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#completionStatus">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#QuestCompletion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Completion state of a quest event.</rdfs:comment>
        <rdfs:label xml:lang="en">completion status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#eventCount -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#eventCount">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameplayEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of times a repeated gameplay behavior occurred in the sample data.</rdfs:comment>
        <rdfs:label xml:lang="en">event count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#eventTimestamp -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#eventTimestamp">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameplayEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Timestamp of a gameplay event.</rdfs:comment>
        <rdfs:label xml:lang="en">event timestamp</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#itemName -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#itemName">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Item"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual display name of an item.</rdfs:comment>
        <rdfs:label xml:lang="en">item name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#level -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#level">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Numeric level of a game character.</rdfs:comment>
        <rdfs:label xml:lang="en">level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#locationName -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#locationName">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual display name of a location.</rdfs:comment>
        <rdfs:label xml:lang="en">location name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#playerName -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#playerName">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual display name of a player profile.</rdfs:comment>
        <rdfs:label xml:lang="en">player name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#preferenceScore -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#preferenceScore">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Recommendation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Simple score used to rank a recommendation in the sample knowledge graph.</rdfs:comment>
        <rdfs:label xml:lang="en">preference score</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#questTitle -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#questTitle">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Quest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual title of a quest.</rdfs:comment>
        <rdfs:label xml:lang="en">quest title</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/rpg-game-character-ontology#recommendationReason -->


    <owl:DatatypeProperty rdf:about="http://example.org/rpg-game-character-ontology#recommendationReason">
        <rdfs:domain rdf:resource="http://example.org/rpg-game-character-ontology#Recommendation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual explanation for why a recommendation was generated.</rdfs:comment>
        <rdfs:label xml:lang="en">recommendation reason</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/rpg-game-character-ontology#Armor -->


    <owl:Class rdf:about="http://example.org/rpg-game-character-ontology#Armor">
        <rdfs:subClassOf rdf:resource="http://example.org/rpg-game-character-ontology#Equipment"/>
        <rdfs:comment xml:lang="en">Equipment used by a character for protection.</rdfs:comment>
        <rdfs:label xml:lang="en">Armor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/rpg-game-character-ontology#BossEnemy -->


    <owl:Class rdf:about="http://example.org/rpg-game-character-ontology#BossEnemy">
        <rdfs:subClassOf rdf:resource="http://example.org/rpg-game-character-ontology#Enemy"/>
        <rdfs:comment xml:lang="en">A powerful enemy usually associated with an important challenge.</rdfs:comment>
        <rdfs:label xml:lang="en">Boss Enemy</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/rpg-game-character-ontology#CharacterClass -->


    <owl:Class rdf:about="http://example.org/rpg-game-character-ontology#CharacterClass">
        <rdfs:subClassOf rdf:resource="http://example.org/rpg-game-character-ontology#GameEntity"/>
        <rdfs:comment xml:lang="en">A role or profession of a character, such as Warrior, Mage, Ranger, or Sage.</rdfs:comment>
        <rdfs:label xml:lang="en">Character Class</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/rpg-game-character-ontology#CharacterProgression -->


    <owl:Class rdf:about="http://example.org/rpg-game-character-ontology#CharacterProgression">
        <rdfs:comment xml:lang="en">A representation of character development over time, such as level growth or repeated skill usage.</rdfs:comment>
        <rdfs:label xml:lang="en">Character Progression</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/rpg-game-character-ontology#ConsumableItem -->


    <owl:Class rdf:about="http://example.org/rpg-game-character-ontology#ConsumableItem">
        <rdfs:subClassOf rdf:resource="http://example.org/rpg-game-character-ontology#Item"/>
        <rdfs:comment xml:lang="en">An item that can be consumed by a character.</rdfs:comment>
        <rdfs:label xml:lang="en">Consumable Item</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/rpg-game-character-ontology#Enemy -->


    <owl:Class rdf:about="http://example.org/rpg-game-character-ontology#Enemy">
        <rdfs:subClassOf rdf:resource="http://example.org/rpg-game-character-ontology#GameCharacter"/>
        <rdfs:comment xml:lang="en">A hostile character that can oppose player characters.</rdfs:comment>
        <rdfs:label xml:lang="en">Enemy</rdfs:label>
    </owl:Class>
    


