  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "An OWL/RDF ontology for a small-scale RPG game character and quest knowledge graph, extended in v2 with data acquisition, player behavior events, and recommendation-oriented concepts."
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "RPG Game Character Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "rpg"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "http://example.org/rpg-game-character-ontology#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Version 2 of a small-scale ontology for modeling RPG game characters, quests, items, locations, player behavior events, play styles, and simple recommendations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "RPG Game Character Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "2.0"
  } ]
