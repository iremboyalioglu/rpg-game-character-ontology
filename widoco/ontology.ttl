@prefix : <http://example.org/rpg-game-character-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/rpg-game-character-ontology#> .

<http://example.org/rpg-game-character-ontology#> rdf:type owl:Ontology ;
                                                   <http://purl.org/dc/terms/creator> "Yunus Erdem Ocak" ,
                                                                                      "İrem Boyalıoğlu" ;
                                                   <http://purl.org/dc/terms/description> "An OWL/RDF ontology for a small-scale RPG game character and quest knowledge graph, extended in v2 with data acquisition, player behavior events, and recommendation-oriented concepts."@en ;
                                                   <http://purl.org/dc/terms/title> "RPG Game Character Ontology"@en ;
                                                   <http://purl.org/vocab/vann/preferredNamespacePrefix> "rpg" ;
                                                   <http://purl.org/vocab/vann/preferredNamespaceUri> "http://example.org/rpg-game-character-ontology#" ;
                                                   rdfs:comment "Version 2 of a small-scale ontology for modeling RPG game characters, quests, items, locations, player behavior events, play styles, and simple recommendations."@en ;
                                                   rdfs:label "RPG Game Character Ontology"@en ;
                                                   owl:versionInfo "2.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/rpg-game-character-ontology#allyOf
:allyOf rdf:type owl:ObjectProperty ,
                 owl:SymmetricProperty ;
        rdfs:domain :GameCharacter ;
        rdfs:range :GameCharacter ;
        rdfs:comment "Relates two game characters that are allies."@en ;
        rdfs:label "ally of"@en .


###  http://example.org/rpg-game-character-ontology#belongsToFaction
:belongsToFaction rdf:type owl:ObjectProperty ;
                  rdfs:domain :GameCharacter ;
                  rdfs:range :Faction ;
                  rdfs:comment "Relates a game character to a faction."@en ;
                  rdfs:label "belongs to faction"@en .


###  http://example.org/rpg-game-character-ontology#completedQuest
:completedQuest rdf:type owl:ObjectProperty ;
                rdfs:domain :QuestCompletion ;
                rdfs:range :Quest ;
                rdfs:comment "Relates a quest completion event to the completed quest."@en ;
                rdfs:label "completed quest"@en .


###  http://example.org/rpg-game-character-ontology#controlsCharacter
:controlsCharacter rdf:type owl:ObjectProperty ;
                   rdfs:domain :Player ;
                   rdfs:range :PlayerCharacter ;
                   rdfs:comment "Relates a player profile to the player character controlled by that player."@en ;
                   rdfs:label "controls character"@en .


###  http://example.org/rpg-game-character-ontology#enemyOf
:enemyOf rdf:type owl:ObjectProperty ,
                  owl:SymmetricProperty ;
         rdfs:domain :GameCharacter ;
         rdfs:range :GameCharacter ;
         rdfs:comment "Relates two game characters that are enemies."@en ;
         rdfs:label "enemy of"@en .


###  http://example.org/rpg-game-character-ontology#eventForCharacter
:eventForCharacter rdf:type owl:ObjectProperty ;
                   rdfs:domain :GameplayEvent ;
                   rdfs:range :GameCharacter ;
                   rdfs:comment "Relates a gameplay event to the character involved in that event."@en ;
                   rdfs:label "event for character"@en .


###  http://example.org/rpg-game-character-ontology#eventRelatedQuest
:eventRelatedQuest rdf:type owl:ObjectProperty ;
                   rdfs:domain :GameplayEvent ;
                   rdfs:range :Quest ;
                   rdfs:comment "Relates a gameplay event to the quest involved in the event."@en ;
                   rdfs:label "event related quest"@en .


###  http://example.org/rpg-game-character-ontology#eventUsesSkill
:eventUsesSkill rdf:type owl:ObjectProperty ;
                rdfs:domain :SkillUsage ;
                rdfs:range :Skill ;
                rdfs:comment "Relates a skill usage event to the skill used."@en ;
                rdfs:label "event uses skill"@en .


###  http://example.org/rpg-game-character-ontology#givesQuest
:givesQuest rdf:type owl:ObjectProperty ;
            rdfs:domain :NonPlayerCharacter ;
            rdfs:range :Quest ;
            rdfs:comment "Relates an NPC to a quest that the NPC gives."@en ;
            rdfs:label "gives quest"@en .


###  http://example.org/rpg-game-character-ontology#hasClass
:hasClass rdf:type owl:ObjectProperty ;
          rdfs:domain :GameCharacter ;
          rdfs:range :CharacterClass ;
          rdfs:comment "Relates a game character to a character class."@en ;
          rdfs:label "has class"@en .


###  http://example.org/rpg-game-character-ontology#hasPlayStyle
:hasPlayStyle rdf:type owl:ObjectProperty ;
              rdfs:domain :Player ;
              rdfs:range :PlayStyle ;
              rdfs:comment "Relates a player to a high-level play style category."@en ;
              rdfs:label "has play style"@en .


###  http://example.org/rpg-game-character-ontology#hasRace
:hasRace rdf:type owl:ObjectProperty ;
         rdfs:domain :GameCharacter ;
         rdfs:range :Race ;
         rdfs:comment "Relates a game character to a race."@en ;
         rdfs:label "has race"@en .


###  http://example.org/rpg-game-character-ontology#hasSkill
:hasSkill rdf:type owl:ObjectProperty ;
          rdfs:domain :GameCharacter ;
          rdfs:range :Skill ;
          rdfs:comment "Relates a game character to a skill."@en ;
          rdfs:label "has skill"@en .


###  http://example.org/rpg-game-character-ontology#locatedIn
:locatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :GameEntity ;
           rdfs:range :Location ;
           rdfs:comment "Relates a game entity to a location."@en ;
           rdfs:label "located in"@en .


###  http://example.org/rpg-game-character-ontology#participatesInQuest
:participatesInQuest rdf:type owl:ObjectProperty ;
                     rdfs:domain :GameCharacter ;
                     rdfs:range :Quest ;
                     rdfs:comment "Relates a character to a quest in which the character participates."@en ;
                     rdfs:label "participates in quest"@en .


###  http://example.org/rpg-game-character-ontology#performsEvent
:performsEvent rdf:type owl:ObjectProperty ;
               rdfs:domain :Player ;
               rdfs:range :GameplayEvent ;
               rdfs:comment "Relates a player to a gameplay event performed by that player."@en ;
               rdfs:label "performs event"@en .


###  http://example.org/rpg-game-character-ontology#recommendationForPlayer
:recommendationForPlayer rdf:type owl:ObjectProperty ;
                         rdfs:domain :Recommendation ;
                         rdfs:range :Player ;
                         rdfs:comment "Relates a recommendation to the player for whom it was generated."@en ;
                         rdfs:label "recommendation for player"@en .


###  http://example.org/rpg-game-character-ontology#recommendedQuest
:recommendedQuest rdf:type owl:ObjectProperty ;
                  rdfs:domain :Recommendation ;
                  rdfs:range :Quest ;
                  rdfs:comment "Relates a recommendation to a suggested quest."@en ;
                  rdfs:label "recommended quest"@en .


###  http://example.org/rpg-game-character-ontology#recommendedSkill
:recommendedSkill rdf:type owl:ObjectProperty ;
                  rdfs:domain :Recommendation ;
                  rdfs:range :Skill ;
                  rdfs:comment "Relates a recommendation to a suggested skill."@en ;
                  rdfs:label "recommended skill"@en .


###  http://example.org/rpg-game-character-ontology#requiresSkill
:requiresSkill rdf:type owl:ObjectProperty ;
               rdfs:domain :Quest ;
               rdfs:range :Skill ;
               rdfs:comment "Relates a quest to a skill required for completing it."@en ;
               rdfs:label "requires skill"@en .


###  http://example.org/rpg-game-character-ontology#rewardsItem
:rewardsItem rdf:type owl:ObjectProperty ;
             rdfs:domain :Quest ;
             rdfs:range :Item ;
             rdfs:comment "Relates a quest to an item rewarded after completion."@en ;
             rdfs:label "rewards item"@en .


###  http://example.org/rpg-game-character-ontology#usesWeapon
:usesWeapon rdf:type owl:ObjectProperty ;
            rdfs:domain :GameCharacter ;
            rdfs:range :Weapon ;
            rdfs:comment "Relates a game character to a weapon used by that character."@en ;
            rdfs:label "uses weapon"@en .


###  http://example.org/rpg-game-character-ontology#wearsArmor
:wearsArmor rdf:type owl:ObjectProperty ;
            rdfs:domain :GameCharacter ;
            rdfs:range :Armor ;
            rdfs:comment "Relates a game character to armor worn by that character."@en ;
            rdfs:label "wears armor"@en .


#################################################################
#    Data properties
#################################################################

###  http://example.org/rpg-game-character-ontology#characterName
:characterName rdf:type owl:DatatypeProperty ;
               rdfs:domain :GameCharacter ;
               rdfs:range xsd:string ;
               rdfs:comment "Textual display name of a character."@en ;
               rdfs:label "character name"@en .


###  http://example.org/rpg-game-character-ontology#completionStatus
:completionStatus rdf:type owl:DatatypeProperty ;
                  rdfs:domain :QuestCompletion ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Completion state of a quest event."@en ;
                  rdfs:label "completion status"@en .


###  http://example.org/rpg-game-character-ontology#eventCount
:eventCount rdf:type owl:DatatypeProperty ;
            rdfs:domain :GameplayEvent ;
            rdfs:range xsd:integer ;
            rdfs:comment "Number of times a repeated gameplay behavior occurred in the sample data."@en ;
            rdfs:label "event count"@en .


###  http://example.org/rpg-game-character-ontology#eventTimestamp
:eventTimestamp rdf:type owl:DatatypeProperty ;
                rdfs:domain :GameplayEvent ;
                rdfs:range xsd:dateTime ;
                rdfs:comment "Timestamp of a gameplay event."@en ;
                rdfs:label "event timestamp"@en .


###  http://example.org/rpg-game-character-ontology#itemName
:itemName rdf:type owl:DatatypeProperty ;
          rdfs:domain :Item ;
          rdfs:range xsd:string ;
          rdfs:comment "Textual display name of an item."@en ;
          rdfs:label "item name"@en .


###  http://example.org/rpg-game-character-ontology#level
:level rdf:type owl:DatatypeProperty ;
       rdfs:domain :GameCharacter ;
       rdfs:range xsd:integer ;
       rdfs:comment "Numeric level of a game character."@en ;
       rdfs:label "level"@en .


###  http://example.org/rpg-game-character-ontology#locationName
:locationName rdf:type owl:DatatypeProperty ;
              rdfs:domain :Location ;
              rdfs:range xsd:string ;
              rdfs:comment "Textual display name of a location."@en ;
              rdfs:label "location name"@en .


###  http://example.org/rpg-game-character-ontology#playerName
:playerName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Player ;
            rdfs:range xsd:string ;
            rdfs:comment "Textual display name of a player profile."@en ;
            rdfs:label "player name"@en .


###  http://example.org/rpg-game-character-ontology#preferenceScore
:preferenceScore rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Recommendation ;
                 rdfs:range xsd:decimal ;
                 rdfs:comment "Simple score used to rank a recommendation in the sample knowledge graph."@en ;
                 rdfs:label "preference score"@en .


###  http://example.org/rpg-game-character-ontology#questTitle
:questTitle rdf:type owl:DatatypeProperty ;
            rdfs:domain :Quest ;
            rdfs:range xsd:string ;
            rdfs:comment "Textual title of a quest."@en ;
            rdfs:label "quest title"@en .


###  http://example.org/rpg-game-character-ontology#recommendationReason
:recommendationReason rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Recommendation ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Textual explanation for why a recommendation was generated."@en ;
                      rdfs:label "recommendation reason"@en .


#################################################################
#    Classes
#################################################################

###  http://example.org/rpg-game-character-ontology#Armor
:Armor rdf:type owl:Class ;
       rdfs:subClassOf :Equipment ;
       rdfs:comment "Equipment used by a character for protection."@en ;
       rdfs:label "Armor"@en .


###  http://example.org/rpg-game-character-ontology#BossEnemy
:BossEnemy rdf:type owl:Class ;
           rdfs:subClassOf :Enemy ;
           rdfs:comment "A powerful enemy usually associated with an important challenge."@en ;
           rdfs:label "Boss Enemy"@en .


###  http://example.org/rpg-game-character-ontology#CharacterClass
:CharacterClass rdf:type owl:Class ;
                rdfs:subClassOf :GameEntity ;
                rdfs:comment "A role or profession of a character, such as Warrior, Mage, Ranger, or Sage."@en ;
                rdfs:label "Character Class"@en .


###  http://example.org/rpg-game-character-ontology#CharacterProgression
:CharacterProgression rdf:type owl:Class ;
                      rdfs:comment "A representation of character development over time, such as level growth or repeated skill usage."@en ;
                      rdfs:label "Character Progression"@en .


###  http://example.org/rpg-game-character-ontology#ConsumableItem
:ConsumableItem rdf:type owl:Class ;
                rdfs:subClassOf :Item ;
                rdfs:comment "An item that can be consumed by a character."@en ;
                rdfs:label "Consumable Item"@en .


###  http://example.org/rpg-game-character-ontology#Enemy
:Enemy rdf:type owl:Class ;
       rdfs:subClassOf :GameCharacter ;
       rdfs:comment "A hostile character that can oppose player characters."@en ;
       rdfs:label "Enemy"@en .


###  http://example.org/rpg-game-character-ontology#Equipment
:Equipment rdf:type owl:Class ;
           rdfs:subClassOf :GameEntity ;
           rdfs:comment "An item that can be equipped by a character."@en ;
           rdfs:label "Equipment"@en .


###  http://example.org/rpg-game-character-ontology#Faction
:Faction rdf:type owl:Class ;
         rdfs:subClassOf :GameEntity ;
         rdfs:comment "A group or organization that characters may belong to."@en ;
         rdfs:label "Faction"@en .


###  http://example.org/rpg-game-character-ontology#GameCharacter
:GameCharacter rdf:type owl:Class ;
               rdfs:subClassOf :GameEntity ;
               rdfs:comment "A character entity in the game world."@en ;
               rdfs:label "Game Character"@en .


###  http://example.org/rpg-game-character-ontology#GameEntity
:GameEntity rdf:type owl:Class ;
            rdfs:comment "A general entity that exists in the RPG game world."@en ;
            rdfs:label "Game Entity"@en .


###  http://example.org/rpg-game-character-ontology#GameplayEvent
:GameplayEvent rdf:type owl:Class ;
               rdfs:comment "An event generated by player activity, such as completing a quest or using a skill."@en ;
               rdfs:label "Gameplay Event"@en .


###  http://example.org/rpg-game-character-ontology#Item
:Item rdf:type owl:Class ;
      rdfs:subClassOf :GameEntity ;
      rdfs:comment "A general object in the game world."@en ;
      rdfs:label "Item"@en .


###  http://example.org/rpg-game-character-ontology#Location
:Location rdf:type owl:Class ;
          rdfs:subClassOf :GameEntity ;
          rdfs:comment "A place or area in the game world."@en ;
          rdfs:label "Location"@en .


###  http://example.org/rpg-game-character-ontology#NonPlayerCharacter
:NonPlayerCharacter rdf:type owl:Class ;
                    rdfs:subClassOf :GameCharacter ;
                    rdfs:comment "A character controlled by the game system."@en ;
                    rdfs:label "Non-Player Character"@en .


###  http://example.org/rpg-game-character-ontology#PlayStyle
:PlayStyle rdf:type owl:Class ;
           rdfs:comment "A high-level behavioral category inferred from player activity, such as Explorer, CombatFocused, or QuestOriented."@en ;
           rdfs:label "Play Style"@en .


###  http://example.org/rpg-game-character-ontology#Player
:Player rdf:type owl:Class ;
        rdfs:comment "A human user or player profile that controls one or more player characters."@en ;
        rdfs:label "Player"@en .


###  http://example.org/rpg-game-character-ontology#PlayerCharacter
:PlayerCharacter rdf:type owl:Class ;
                 rdfs:subClassOf :GameCharacter ;
                 rdfs:comment "A character controlled by the player."@en ;
                 rdfs:label "Player Character"@en .


###  http://example.org/rpg-game-character-ontology#Quest
:Quest rdf:type owl:Class ;
       rdfs:subClassOf :GameEntity ;
       rdfs:comment "A mission or task in the game world."@en ;
       rdfs:label "Quest"@en .


###  http://example.org/rpg-game-character-ontology#QuestCompletion
:QuestCompletion rdf:type owl:Class ;
                 rdfs:subClassOf :GameplayEvent ;
                 rdfs:comment "A gameplay event representing the completion of a quest."@en ;
                 rdfs:label "Quest Completion"@en .


###  http://example.org/rpg-game-character-ontology#Race
:Race rdf:type owl:Class ;
      rdfs:subClassOf :GameEntity ;
      rdfs:comment "The species or ancestry of a character."@en ;
      rdfs:label "Race"@en .


###  http://example.org/rpg-game-character-ontology#Recommendation
:Recommendation rdf:type owl:Class ;
                rdfs:comment "A suggested quest, skill, or item generated from ontology-based player and character information."@en ;
                rdfs:label "Recommendation"@en .


###  http://example.org/rpg-game-character-ontology#Skill
:Skill rdf:type owl:Class ;
       rdfs:subClassOf :GameEntity ;
       rdfs:comment "An ability that can be used by a character."@en ;
       rdfs:label "Skill"@en .


###  http://example.org/rpg-game-character-ontology#SkillUsage
:SkillUsage rdf:type owl:Class ;
            rdfs:subClassOf :GameplayEvent ;
            rdfs:comment "A gameplay event representing the use of a skill by a character."@en ;
            rdfs:label "Skill Usage"@en .


###  http://example.org/rpg-game-character-ontology#Weapon
:Weapon rdf:type owl:Class ;
        rdfs:subClassOf :Equipment ;
        rdfs:comment "Equipment used by a character for attacking."@en ;
        rdfs:label "Weapon"@en .


#################################################################
#    Individuals
#################################################################

###  http://example.org/rpg-game-character-ontology#AdventurersGuild
:AdventurersGuild rdf:type owl:NamedIndividual ,
                           :Faction ;
                  rdfs:label "Adventurers Guild"@en .


###  http://example.org/rpg-game-character-ontology#AncientAmulet
:AncientAmulet rdf:type owl:NamedIndividual ,
                        :Item ;
               :itemName "Ancient Amulet" .


###  http://example.org/rpg-game-character-ontology#AncientKnowledge
:AncientKnowledge rdf:type owl:NamedIndividual ,
                           :Skill ;
                  rdfs:label "Ancient Knowledge"@en .


###  http://example.org/rpg-game-character-ontology#ArcaneShield
:ArcaneShield rdf:type owl:NamedIndividual ,
                       :Skill ;
              rdfs:label "Arcane Shield"@en .


###  http://example.org/rpg-game-character-ontology#Arin
:Arin rdf:type owl:NamedIndividual ,
               :PlayerCharacter ;
      :allyOf :Lyra ;
      :belongsToFaction :AdventurersGuild ;
      :enemyOf :DarkLord ;
      :hasClass :Warrior ;
      :hasRace :Human ;
      :hasSkill :PowerStrike ,
                :ShieldBlock ;
      :locatedIn :OldVillage ;
      :participatesInQuest :LostRelicQuest ;
      :usesWeapon :IronSword ;
      :wearsArmor :LeatherArmor ;
      :characterName "Arin" ;
      :level 12 .


###  http://example.org/rpg-game-character-ontology#ClothRobe
:ClothRobe rdf:type owl:NamedIndividual ,
                    :Armor ;
           rdfs:label "Cloth Robe"@en .


###  http://example.org/rpg-game-character-ontology#CombatFocused
:CombatFocused rdf:type owl:NamedIndividual ,
                        :PlayStyle ;
               rdfs:label "Combat Focused"@en .


###  http://example.org/rpg-game-character-ontology#DarkArmor
:DarkArmor rdf:type owl:NamedIndividual ,
                    :Armor ;
           rdfs:label "Dark Armor"@en .


###  http://example.org/rpg-game-character-ontology#DarkForest
:DarkForest rdf:type owl:NamedIndividual ,
                     :Location ;
            :locationName "Dark Forest" .


###  http://example.org/rpg-game-character-ontology#DarkLord
:DarkLord rdf:type owl:NamedIndividual ,
                   :BossEnemy ;
          :belongsToFaction :ShadowCult ;
          :enemyOf :Arin ,
                   :Kael ,
                   :Lyra ;
          :hasClass :Mage ;
          :hasRace :Human ;
          :hasSkill :Fireball ,
                    :ShadowCurse ;
          :locatedIn :ShadowCastle ;
          :usesWeapon :ShadowStaff ;
          :wearsArmor :DarkArmor ;
          :characterName "Dark Lord" ;
          :level 40 .


###  http://example.org/rpg-game-character-ontology#ElderMira
:ElderMira rdf:type owl:NamedIndividual ,
                    :NonPlayerCharacter ;
           :belongsToFaction :AdventurersGuild ;
           :givesQuest :HerbGatheringQuest ,
                       :LostRelicQuest ,
                       :ShadowGateQuest ;
           :hasClass :Sage ;
           :hasRace :Human ;
           :hasSkill :AncientKnowledge ;
           :locatedIn :OldVillage ;
           :characterName "Elder Mira" ;
           :level 20 .


###  http://example.org/rpg-game-character-ontology#Elf
:Elf rdf:type owl:NamedIndividual ,
              :Race ;
     rdfs:label "Elf"@en .


###  http://example.org/rpg-game-character-ontology#Event001
:Event001 rdf:type owl:NamedIndividual ,
                   :QuestCompletion ;
          :completedQuest :LostRelicQuest ;
          :eventForCharacter :Arin ;
          :eventRelatedQuest :LostRelicQuest ;
          :completionStatus "completed" ;
          :eventCount 1 ;
          :eventTimestamp "2026-04-20T18:30:00"^^xsd:dateTime .


###  http://example.org/rpg-game-character-ontology#Event002
:Event002 rdf:type owl:NamedIndividual ,
                   :SkillUsage ;
          :eventForCharacter :Arin ;
          :eventRelatedQuest :LostRelicQuest ;
          :eventUsesSkill :PowerStrike ;
          :eventCount 7 ;
          :eventTimestamp "2026-04-20T18:45:00"^^xsd:dateTime .


###  http://example.org/rpg-game-character-ontology#Event003
:Event003 rdf:type owl:NamedIndividual ,
                   :SkillUsage ;
          :eventForCharacter :Lyra ;
          :eventRelatedQuest :ShadowGateQuest ;
          :eventUsesSkill :Fireball ;
          :eventCount 12 ;
          :eventTimestamp "2026-04-21T20:00:00"^^xsd:dateTime .


###  http://example.org/rpg-game-character-ontology#Event004
:Event004 rdf:type owl:NamedIndividual ,
                   :QuestCompletion ;
          :completedQuest :HerbGatheringQuest ;
          :eventForCharacter :Kael ;
          :eventRelatedQuest :HerbGatheringQuest ;
          :completionStatus "completed" ;
          :eventCount 1 ;
          :eventTimestamp "2026-04-22T17:20:00"^^xsd:dateTime .


###  http://example.org/rpg-game-character-ontology#Explorer
:Explorer rdf:type owl:NamedIndividual ,
                   :PlayStyle ;
          rdfs:label "Explorer"@en .


###  http://example.org/rpg-game-character-ontology#Fireball
:Fireball rdf:type owl:NamedIndividual ,
                   :Skill ;
          rdfs:label "Fireball"@en .


###  http://example.org/rpg-game-character-ontology#GoblinWarrior
:GoblinWarrior rdf:type owl:NamedIndividual ,
                        :Enemy ;
               :belongsToFaction :ShadowCult ;
               :enemyOf :Arin ;
               :hasClass :Warrior ;
               :hasRace :Orc ;
               :hasSkill :PowerStrike ;
               :locatedIn :DarkForest ;
               :usesWeapon :IronSword ;
               :wearsArmor :LeatherArmor ;
               :characterName "Goblin Warrior" ;
               :level 5 .


###  http://example.org/rpg-game-character-ontology#HealingPotion
:HealingPotion rdf:type owl:NamedIndividual ,
                        :ConsumableItem ;
               :itemName "Healing Potion" .


###  http://example.org/rpg-game-character-ontology#HerbGatheringQuest
:HerbGatheringQuest rdf:type owl:NamedIndividual ,
                             :Quest ;
                    :locatedIn :DarkForest ;
                    :requiresSkill :Tracking ;
                    :rewardsItem :ManaPotion ;
                    :questTitle "Forest Herbs" .


###  http://example.org/rpg-game-character-ontology#Human
:Human rdf:type owl:NamedIndividual ,
